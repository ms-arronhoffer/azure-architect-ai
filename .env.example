# ============================================================================
# Azure Architect AI — backend configuration
# Copy to backend/.env (or repo-root .env) and fill in values.
# All settings map to fields in backend/config.py (case-insensitive).
# ============================================================================

# ---- Azure OpenAI (required) ----
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
# Omit AZURE_OPENAI_KEY to use az login / DefaultAzureCredential (recommended).
# AZURE_OPENAI_KEY=<your-key>

# Deployment names in your Azure OpenAI resource (NOT model names).
AZURE_OPENAI_DEPLOYMENT_CHAT=gpt-4o-mini
AZURE_OPENAI_DEPLOYMENT_ARCH=gpt-4.1
AZURE_OPENAI_DEPLOYMENT_EMBEDDING=text-embedding-ada-002
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# ---- RAG ----
# When true, reference architectures are embedded at startup and Learn queries
# are cached. Requires a working embedding deployment above; otherwise RAG
# silently no-ops and the app falls back to the live Learn API.
RAG_ENABLED=true
RAG_TOP_K=5

# ---- Azure MCP integration ----
# Subscription-scoped tools (resource graph, cost, etc.) require a subscription.
MCP_ENABLED=true
# AZURE_SUBSCRIPTION_ID=<your-subscription-id>

# ---- Database ----
# Default is local SQLite. For Postgres use the async driver:
#   postgresql+asyncpg://user:pass@host:5432/aa
DATABASE_URL=sqlite+aiosqlite:///./data/conversations.db

# ---- Secret-at-rest encryption ----
# Required to store user secrets (e.g., GitHub PATs). Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# SECRET_ENCRYPTION_KEY=<base64-32-byte-fernet-key>

# ---- Entra ID auth ----
# When AUTH_ENABLED=true, all /api/* routes require a Bearer JWT.
AUTH_ENABLED=false
# ENTRA_TENANT_ID=<tenant-guid>
# ENTRA_AUDIENCE=<api-app-registration-client-id-or-app-id-uri>
SESSION_COOKIE_NAME=aa_session
SESSION_COOKIE_SECURE=false  # set true behind HTTPS

# ---- Observability ----
# When set, OpenTelemetry exports traces, logs, and metrics to App Insights.
# APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...;IngestionEndpoint=...

# ---- Trusted-oracle feature flag (Themes 1-4) ----
# The 5-agent unified surface (architect, cost, operations, compliance,
# engagement) is opt-in: set both to true to enable it. Anything else —
# including unset — uses the legacy 84-mode routing. Keep them in sync —
# the backend collapses prompt routing, the frontend collapses the SideNav.
UNIFIED_AGENTS=false
VITE_UNIFIED_AGENTS=false

# ---- Custom skills feature flag ----
# Per-user uploadable skills + Skill Showcase. Opt-in: set both to true to
# expose the "My Skills" / "Skill Showcase" surface. Anything else (including
# unset) hides the feature and the /api/skills* routes return 404.
CUSTOM_SKILLS=false
VITE_CUSTOM_SKILLS=false

# ---- Scheduled ingests (Azure Updates, AVM, refarch, demos) ----
INGEST_ENABLED=false
