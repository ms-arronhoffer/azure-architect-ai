# ============================================================================
# Azure Architect AI — backend configuration
# Copy to backend/.env (or repo-root .env) and fill in values.
# All settings map to fields in backend/config.py (case-insensitive).
# ============================================================================

# ---- Azure OpenAI (required) ----
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
# Omit AZURE_OPENAI_KEY to use DefaultAzureCredential (recommended).
# Local host: `az login` works. In Docker: set the service principal vars below
# (created via `az ad sp create-for-rbac` + "Cognitive Services OpenAI User" role).
# AZURE_OPENAI_KEY=<your-key>
# AZURE_TENANT_ID=<tenant-guid>
# AZURE_CLIENT_ID=<app-registration-client-id>
# AZURE_CLIENT_SECRET=<app-registration-client-secret>

# Deployment names in your Azure OpenAI resource (NOT model names).
AZURE_OPENAI_DEPLOYMENT_CHAT=gpt-4o-mini
AZURE_OPENAI_DEPLOYMENT_ARCH=gpt-4.1
# Pricing Desk (architecture pricing) diagram/text extraction LLM.
AZURE_OPENAI_DEPLOYMENT_PRICING=gpt-5.4-mini
AZURE_OPENAI_DEPLOYMENT_EMBEDDING=text-embedding-ada-002
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# ---- RAG ----
# When true, reference architectures are embedded at startup and Learn queries
# are cached. Requires a working embedding deployment above; otherwise RAG
# silently no-ops and the app falls back to the live Learn API.
RAG_ENABLED=true
RAG_TOP_K=5

# ---- Azure MCP integration ----
# Subscription-scoped tools (resource graph, cost, etc.) require a subscription.
MCP_ENABLED=true
# AZURE_SUBSCRIPTION_ID=<your-subscription-id>

# ---- Database ----
# Default is local SQLite. For Postgres use the async driver:
#   postgresql+asyncpg://user:pass@host:5432/aa
DATABASE_URL=sqlite+aiosqlite:///./data/conversations.db

# ---- Secret-at-rest encryption ----
# Required to store user secrets (e.g., GitHub PATs). Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# SECRET_ENCRYPTION_KEY=<base64-32-byte-fernet-key>

# ---- Entra ID auth ----
# When AUTH_ENABLED=true, all /api/* routes require a Bearer JWT.
# Frontend (Vite) needs matching VITE_AUTH_ENABLED / VITE_ENTRA_* in the
# repo-root .env so docker-compose can forward them into the SPA container.
AUTH_ENABLED=false
# ENTRA_TENANT_ID=<tenant-guid>
# ENTRA_AUDIENCE=<api-app-registration-client-id-or-app-id-uri>
# VITE_AUTH_ENABLED=true
# VITE_ENTRA_TENANT_ID=<tenant-guid>
# VITE_ENTRA_CLIENT_ID=<spa-app-registration-client-id>
# VITE_ENTRA_API_SCOPE=api://<api-app-registration-client-id>/access_as_user
SESSION_COOKIE_NAME=aa_session
SESSION_COOKIE_SECURE=false  # set true behind HTTPS

# ---- Observability ----
# When set, OpenTelemetry exports traces, logs, and metrics to App Insights.
# APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...;IngestionEndpoint=...

# ---- Trusted-oracle feature flag ----
# When true, the agent router and chat dispatch use the 5-agent taxonomy
# (architect, cost, operations, compliance, engagement) instead of the 84
# legacy modes. This value is also served to the SPA at runtime via
# GET /api/config, so flipping it (and restarting the backend) changes the
# frontend surface without a rebuild. The frontend's VITE_UNIFIED_AGENTS is now
# only a pre-fetch fallback.
UNIFIED_AGENTS=false

# ---- Scheduled ingest toggles ----
# Daily Azure Updates RSS + weekly AVM / Reference Arch / Demo refresh.
# Disable in dev to keep the scheduler quiet; enable in dev-slot/prod.
INGEST_ENABLED=false
