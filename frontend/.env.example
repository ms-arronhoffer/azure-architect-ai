# Frontend build-time configuration.
#
# Leave VITE_API_BASE_URL UNSET for local dev — Vite's proxy in vite.config.ts
# forwards /api/* to http://localhost:8000.
#
# Set this for split-host deploys where the SPA and API are on different origins
# (e.g. SPA on Azure Static Web Apps, API on Azure Container Apps).
# Example:
#   VITE_API_BASE_URL=https://api.architect.example.com
#
# Do NOT include a trailing slash; api.ts strips it but cleaner without.
# VITE_API_BASE_URL=

# Feature flag — the 5 unified agents (architect, cost, operations, compliance,
# engagement) are the default surface; opt out to restore the legacy 84-mode
# SideNav. This Vite var is now only a *fallback* used before the SPA fetches
# the runtime value from GET /api/config (driven by the backend UNIFIED_AGENTS
# env). Prefer setting the backend flag so the surface can change without a
# frontend rebuild; users can also toggle it per-browser from Settings.
# VITE_UNIFIED_AGENTS=true

# Feature flag — per-user custom skills + Skill Showcase. Fallback used before
# the SPA fetches the runtime value from GET /api/config (driven by the backend
# CUSTOM_SKILLS env). Prefer setting the backend flag; users can also toggle it
# per-browser from Settings.
# VITE_CUSTOM_SKILLS=true
